#!/bin/bash
set -e

# Install nanobot from PyPI
pip install nanobot-ai

# Create config directory
mkdir -p /installed-agent

# Generate default config if not provided via environment
{% if config_json %}
echo '{{ config_json }}' > /installed-agent/nanobot_config.json
{% else %}
# Minimal config pointing to the task workspace
cat > /installed-agent/nanobot_config.json << CONFIG_EOF
{
  "agents": {
    "defaults": {
      "model": "{{ model | default('minimax/MiniMax-M2.7') }}",
      "max_tool_iterations": 100,
      "max_tokens": 4096
    }
  },
  "providers": {
    "openai_compat": {
      "api_base": "{{ api_base | default('https://api.minimax.chat/v1') }}",
      "api_key": "${NANOBOT_API_KEY}"
    }
  },
  "channels": {}
}
CONFIG_EOF
{% endif %}

echo "Nanobot installed successfully"
